# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ── AI ────────────────────────────────────────────────────────────────────────
# Get your key from https://openrouter.ai/keys
# Model used: google/gemini-2.0-flash-001 (fast, cheap, great for CRM tasks)
# Any OpenRouter model works — just change the MODEL constant in src/lib/ai*.ts
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Channel Simulator ─────────────────────────────────────────────────────────
# URL of the deployed channel-simulator service.
# If unset, the CRM falls back to its own built-in /api/public/channel/send
# (great for local dev — no separate process needed).
CHANNEL_SIMULATOR_URL=https://your-simulator.up.railway.app

# Shared secret between CRM and simulator for verifying callbacks.
# Set the same value in the simulator's SIMULATOR_SECRET env var.
SIMULATOR_SECRET=change-me-to-a-random-string

# ── App URL (used to build absolute callback URLs) ────────────────────────────
PUBLIC_APP_URL=https://your-crm.lovable.app
