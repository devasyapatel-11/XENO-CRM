# Supabase — same project as the CRM
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret — set the same value in the CRM's SIMULATOR_SECRET env var
# so the CRM can verify callbacks are genuinely from this simulator
SIMULATOR_SECRET=change-me-to-a-random-string

# Port (default 3001)
PORT=3001
