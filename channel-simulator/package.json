{
  "name": "xeno-channel-simulator",
  "version": "1.0.0",
  "description": "Standalone channel simulator service for Xeno CRM. Accepts send requests, simulates delivery lifecycle, and POSTs callbacks.",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --outDir dist --declaration false",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@supabase/supabase-js": "^2.108.1",
    "hono": "^4.7.11"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
